# Zgodne z docker-compose.yml (npm run docker:up):
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/training_websockets?schema=public"

PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=zamien-na-dlugie-losowe
JWT_EXPIRES_IN=7d
JWT_EXPIRES_REMEMBER=30d
AUTH_COOKIE_NAME=access_token
# lax | strict | none (none wymaga secure=true / HTTPS)w
AUTH_COOKIE_SAMESITE=lax
